{
    "timezone": "Asia/Ho_Chi_Minh",
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:best-practices",
        "group:allApollographql",
        "group:allDigest",
        "group:allNonMajor"
    ],
    "ignoreDeps": [
        "node"
    ],
    "rangeStrategy": "bump",
    "schedule": [
        "before 8am on Monday"
    ],
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true,
    "major": {
        "automerge": false
    }
}